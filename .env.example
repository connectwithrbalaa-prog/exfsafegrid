# ── Optional overrides (defaults are safe for production) ─────────────────────
# Claude model used by AI agents. Defaults to claude-opus-4-6.
# CLAUDE_MODEL=claude-opus-4-6

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

